      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Speech recognition is used to transcribe audio files into text. Processing happens on your device and is never sent externally."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "音声ファイルを文字に書き起こすために音声認識を使用します。処理は端末内で行われ、外部に送信されません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "为了将语音文件转录为文字，将使用语音识别功能。处理均在设备本机进行，不会发送至外部。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "為了將語音檔案轉錄為文字，將使用語音辨識功能。處理均在裝置本機進行，不會傳送至外部。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "음성 파일을 텍스트로 변환하기 위해 음성 인식을 사용합니다. 처리는 기기 내에서 이루어지며 외부로 전송되지 않습니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "El reconocimiento de voz se utiliza para transcribir archivos de audio a texto. El procesamiento se realiza en tu dispositivo y nunca se envía al exterior."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Die Spracherkennung wird verwendet, um Audiodateien in Text umzuwandeln. Die Verarbeitung erfolgt auf deinem Gerät und wird niemals extern übermittelt."
