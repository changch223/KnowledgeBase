    "detail.customize.footer" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本文は変えずに、AI が生成する要約・重要な事実の観点をこの方向に寄せて作り直します（本文にある範囲で）。空にして実行すると既定の生成に戻ります。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "正文内容不变，AI 会依此方向重新生成摘要与重要事实的侧重点（仅限正文范围内）。留空执行则恢复为默认生成方式。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "正文內容不變，AI 會依此方向重新產生摘要與重要事實的側重點（僅限正文範圍內）。留空執行則恢復為預設產生方式。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "The article body stays the same — AI will regenerate the summary and key facts with this focus (within what's covered in the body). Leave this empty and run to go back to the default generation."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "본문은 그대로 두고, AI가 생성하는 요약·핵심 사실의 관점을 이 방향에 맞춰 다시 생성합니다(본문에 있는 범위에서). 비워 두고 실행하면 기본 생성으로 돌아갑니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "El cuerpo del artículo no cambia: la IA regenerará el resumen y los datos clave con este enfoque (dentro de lo que cubre el cuerpo). Déjalo vacío y ejecuta para volver a la generación predeterminada."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der Artikeltext bleibt unverändert — die KI erstellt die Zusammenfassung und wichtige Fakten mit diesem Fokus neu (im Rahmen des Textinhalts). Leer lassen und ausführen, um zur Standardgenerierung zurückzukehren."
          }
        }
      }
    },
