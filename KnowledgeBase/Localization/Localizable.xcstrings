    "settings.lint.description" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Erkennt isolierte Konzepte, Duplikate und Kategoriefehlzuordnungen und versucht, sie zu beheben. Läuft automatisch jeden Sonntag um 3:00 Uhr."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Detects isolated concepts, duplicates, and category mismatches, and attempts to fix them. Runs automatically every Sunday at 3:00 AM."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Detecta conceptos aislados, duplicados y categorías incorrectas, e intenta corregirlos. Se ejecuta automáticamente todos los domingos a las 3:00."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "孤立した概念・重複・分野のズレを検知し、修正を試みます。毎週日曜 3:00 に自動実行。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "고립된 개념·중복·분야 불일치를 감지하여 수정을 시도합니다. 매주 일요일 3:00에 자동 실행됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "检测并尝试修正孤立的概念、重复内容与类别偏差。每周日凌晨 3:00 自动执行。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
