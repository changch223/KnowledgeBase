    "settings.chromeSetup.step2.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「自動化」→「個人用オートメーション」→「アプリ」→ Chrome を選択 →「開く」を選択。作成後「実行前に通知」を OFF にしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "「自动化」→「个人自动化」→「App」→ 选择 Chrome →选择「打开」。创建后请将「运行前通知」设为关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "「自動化」→「個人自動化」→「App」→ 選擇 Chrome →選擇「開啟」。建立後請將「執行前通知」設為關閉。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Go to \"Automation\" → \"Create Personal Automation\" → \"App\" → select Chrome → select \"Open\". After creating it, turn off \"Notify Before Running\"."
          }
        }
      }
    },
