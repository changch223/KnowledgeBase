    "onboarding.page1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Knowledge Base はあなたが読んだ記事を AI が自動で整理し、必要なときに思い出せる「あなた専用の第二の脳」です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base 会由 AI 自动整理你读过的文章，让你在需要时随时回想起来，是「专属于你的第二大脑」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base 會由 AI 自動整理你讀過的文章，讓你在需要時隨時回想起來，是「專屬於你的第二大腦」。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base automatically organizes the articles you read with AI, making it your own \"second brain\" you can recall whenever you need."
          }
        }
      }
    },
    "onboarding.page1.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ようこそ Knowledge Base へ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "欢迎使用 Knowledge Base"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "歡迎使用 Knowledge Base"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Welcome to Knowledge Base"
          }
        }
      }
    },
    "onboarding.page2.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "共有シートから記事をそのまま保存。＋ボタンなら URL・テキスト・ファイル・写真・音声も取り込めます。英語や中国語のコンテンツは自動で日本語に翻訳して整理します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "从共享面板可直接保存文章。使用「+」按钮还能导入 URL、文字、文件、照片、语音。英文或中文内容会自动翻译为日文后再整理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "從共享面板可直接儲存文章。使用「+」按鈕還能匯入 URL、文字、檔案、照片、語音。英文或中文內容會自動翻譯為日文後再整理。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Save articles directly from the Share Sheet. The + button also lets you add URLs, text, files, photos, and audio. English or Chinese content is automatically translated to Japanese and organized."
          }
        }
      }
    },
    "onboarding.page2.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どこからでも取り込める"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "随处都能导入"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "隨處都能匯入"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Add Content From Anywhere"
          }
        }
      }
    },
    "onboarding.page3.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "複数の記事をまたいで「概念ページ（Wiki）」を自動生成・更新。ナレッジタブを開けば、テーマごとの要点まとめが常に最新の状態で育っています。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "跨多篇文章自动生成并更新「概念页面（Wiki）」。打开知识标签页，就能看到按主题整理、始终保持最新的要点摘要。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "跨多篇文章自動產生並更新「概念頁面（Wiki）」。開啟知識分頁，就能看到依主題整理、始終保持最新的要點摘要。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI automatically creates and updates \"concept pages (wiki)\" across multiple articles. Open the Knowledge tab and you'll always find up-to-date summaries organized by topic."
          }
        }
      }
    },
    "onboarding.page3.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI が自動で整理"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI 自动整理"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI 自動整理"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI Organizes It Automatically"
          }
        }
      }
    },
    "onboarding.page4.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記事詳細の「訂正」ボタンから自然言語で指示するだけ（例: 「Claude Code を gloadcod と誤認識しています」）。分野の修正は次回の自動分類に活かされます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "只需在文章详情的「更正」按钮中用自然语言下达指示（例如：「Claude Code 被误认成了 gloadcod」）。类别的修正也会应用到下次的自动分类中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "只需在文章詳情的「更正」按鈕中用自然語言下達指示（例如：「Claude Code 被誤認成了 gloadcod」）。類別的修正也會應用到下次的自動分類中。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Just tap the \"Correct\" button on an article's detail page and describe the fix in plain language (e.g. \"Claude Code is being misread as gloadcod\"). Category corrections are applied to future classifications too."
          }
        }
      }
    },
    "onboarding.page4.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI の誤りはすぐ直せる"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI 的错误可以立即修正"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI 的錯誤可以立即修正"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Fix AI Mistakes Instantly"
          }
        }
      }
    },
    "onboarding.page5.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI チャットタブで、保存した記事だけを根拠に質問できます。答えには番号付きの出典が付き、元記事へすぐ戻れます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在 AI 聊天标签页中，可以仅根据已保存的文章进行提问。答案会附上编号出处，方便你随时返回原文章。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在 AI 聊天分頁中，可以僅根據已儲存的文章進行提問。答案會附上編號出處，方便你隨時返回原文章。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "In the AI Chat tab, you can ask questions based only on your saved articles. Answers come with numbered sources so you can jump straight back to the original article."
          }
        }
      }
    },
