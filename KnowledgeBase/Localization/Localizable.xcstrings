    "onboarding.page1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Knowledge Base はあなたが読んだ記事を AI が自動で整理し、必要なときに思い出せる「あなた専用の第二の脳」です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
