        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "開啟下方開關啟用自動儲存後，Safari 中開啟的網頁會自動儲存。關閉時，可點按工具列中的 Knowledge Base 圖示進行儲存。"
          }
        }
      }
