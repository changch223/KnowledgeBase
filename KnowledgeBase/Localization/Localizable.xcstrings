    "settings.safariSetup.confirmAutoSave.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Jede Seite, die du in Safari öffnest, wird automatisch in Knowledge Base gesichert. Zum Schutz deiner Privatsphäre werden Cookie-Zustimmungsseiten, Suchergebnisse, Anmeldeseiten und Ähnliches ausgeschlossen. Du kannst dies jederzeit wieder deaktivieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Every page you open in Safari will be automatically saved to Knowledge Base. To protect your privacy, cookie consent screens, search results, login pages, and similar pages are excluded. You can turn this off anytime."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Cada página que abras en Safari se guardará automáticamente en Knowledge Base. Para proteger tu privacidad, se excluyen las pantallas de consentimiento de cookies, los resultados de búsqueda, las páginas de inicio de sesión y similares. Puedes desactivarlo cuando quieras."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Safari で開いたすべてのページがKnowledge Baseに自動保存されます。プライバシー保護のため、Cookie 同意画面 / 検索結果 / ログイン画面などは除外されます。後でいつでも OFF にできます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Safari에서 연 모든 페이지가 Knowledge Base에 자동으로 저장됩니다. 개인정보 보호를 위해 쿠키 동의 화면 / 검색 결과 / 로그인 화면 등은 제외됩니다. 나중에 언제든지 OFF로 바꿀 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Safari 中打开的所有网页都会自动保存到 Knowledge Base。为保护隐私，Cookie 同意画面、搜索结果、登录画面等会被排除在外。之后随时可以关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Safari 中開啟的所有網頁都會自動儲存到 Knowledge Base。為保護隱私，Cookie 同意畫面、搜尋結果、登入畫面等會被排除在外。之後隨時可以關閉。"
          }
        }
      }
    },
