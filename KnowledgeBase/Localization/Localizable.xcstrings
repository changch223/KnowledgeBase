    "settings.translationSetup.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Wenn du einen englischen Artikel sicherst, übersetzt Knowledge Base ihn mit der iOS-Übersetzungsfunktion ins Deutsche, bevor Wissen extrahiert wird. Bei der ersten Verwendung musst du die Übersetzungsmodelle für Englisch und Deutsch über die iOS-Einstellungen herunterladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "When you save an English article, Knowledge Base uses iOS's translation feature to translate it into Japanese before extracting knowledge. The first time you use this, you'll need to download the English and Japanese translation models from iOS Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Cuando guardas un artículo en inglés, Knowledge Base usa la función de traducción de iOS para traducirlo al japonés antes de extraer el conocimiento. La primera vez que lo uses, deberás descargar los modelos de traducción de inglés y japonés desde Ajustes de iOS."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "英語記事を保存した時に、Knowledge Baseは iOS の翻訳機能を使って日本語に翻訳してから知識を抽出します。初回利用時は英語と日本語の翻訳モデルを iOS Settings からダウンロードする必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "영어 기사를 저장하면 Knowledge Base는 iOS의 번역 기능을 사용해 일본어로 번역한 후 지식을 추출합니다. 처음 사용할 때는 iOS 설정에서 영어와 일본어 번역 모델을 다운로드해야 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "保存英文文章时，Knowledge Base 会使用 iOS 的翻译功能将其翻译为日文后再提取知识。首次使用时需要在 iOS 设置中下载英文与日文的翻译模型。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "儲存英文文章時，Knowledge Base 會使用 iOS 的翻譯功能將其翻譯為日文後再擷取知識。首次使用時需要在 iOS 設定中下載英文與日文的翻譯模型。"
          }
        }
      }
    },
