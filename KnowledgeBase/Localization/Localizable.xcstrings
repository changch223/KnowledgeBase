    "onboarding.page4.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tippe einfach auf die Schaltfläche „Korrigieren“ auf der Artikeldetailseite und beschreibe die Korrektur in einfachen Worten (z. B. „Claude Code wird fälschlicherweise als gloadcod erkannt“). Kategoriekorrekturen fließen auch in zukünftige Klassifizierungen ein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Just tap the \"Correct\" button on an article's detail page and describe the fix in plain language (e.g. \"Claude Code is being misread as gloadcod\"). Category corrections are applied to future classifications too."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Toca el botón \"Corregir\" en la página de detalle de un artículo y describe la corrección en lenguaje natural (p. ej.: \"Claude Code se reconoce mal como gloadcod\"). Las correcciones de categoría también se aplican a futuras clasificaciones."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記事詳細の「訂正」ボタンから自然言語で指示するだけ（例: 「Claude Code を gloadcod と誤認識しています」）。分野の修正は次回の自動分類に活かされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "기사 상세 화면의 '수정' 버튼에서 자연어로 지시하기만 하면 됩니다(예: 'Claude Code를 gloadcod로 잘못 인식하고 있어요'). 분야 수정은 다음 자동 분류에 반영됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "只需在文章详情的「更正」按钮中用自然语言下达指示（例如：「Claude Code 被误认成了 gloadcod」）。类别的修正也会应用到下次的自动分类中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "只需在文章詳情的「更正」按鈕中用自然語言下達指示（例如：「Claude Code 被誤認成了 gloadcod」）。類別的修正也會應用到下次的自動分類中。"
          }
        }
      }
    },
