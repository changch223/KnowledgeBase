    "settings.chromeSetup.step3.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「アクション追加」→ 検索で「Knowledge Base」→「Knowledge Baseに保存」を選択。URL を「Chrome の現在の URL」に設定します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "「添加操作」→ 搜索「Knowledge Base」→ 选择「保存到 Knowledge Base」。将 URL 设置为「Chrome 的当前 URL」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "「新增操作」→ 搜尋「Knowledge Base」→ 選擇「儲存到 Knowledge Base」。將 URL 設定為「Chrome 目前的 URL」。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Tap \"Add Action\" → search \"Knowledge Base\" → select \"Save to Knowledge Base\". Set the URL to \"Chrome's Current URL\"."
          }
        }
      }
    },
