    "onboarding.page5.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Im KI-Chat-Tab kannst du Fragen stellen, die ausschließlich auf deinen gesicherten Artikeln basieren. Antworten enthalten nummerierte Quellen, über die du direkt zum Originalartikel zurückspringen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "In the AI Chat tab, you can ask questions based only on your saved articles. Answers come with numbered sources so you can jump straight back to the original article."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "En la pestaña Chat de IA, puedes hacer preguntas basadas solo en tus artículos guardados. Las respuestas incluyen fuentes numeradas para que puedas volver directamente al artículo original."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI チャットタブで、保存した記事だけを根拠に質問できます。答えには番号付きの出典が付き、元記事へすぐ戻れます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI 채팅 탭에서 저장한 기사만을 근거로 질문할 수 있습니다. 답변에는 번호가 매겨진 출처가 붙어 원본 기사로 바로 돌아갈 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在 AI 聊天标签页中，可以仅根据已保存的文章进行提问。答案会附上编号出处，方便你随时返回原文章。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "在 AI 聊天分頁中，可以僅根據已儲存的文章進行提問。答案會附上編號出處，方便你隨時返回原文章。"
          }
        }
      }
    },
