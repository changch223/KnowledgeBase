    "settings.chromeSetup.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "以下の手順で Chrome 用の自動化を作成できます。Safari をお使いの方は、上の「Safari ツールバーで保存」のセットアップをおすすめします (より簡単で安定動作)。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "按照以下步骤即可创建 Chrome 专用的自动化。若你使用 Safari，建议改用上方的「通过 Safari 工具栏保存」设置（更简单且更稳定）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "按照以下步驟即可建立 Chrome 專用的自動化。若你使用 Safari，建議改用上方的「透過 Safari 工具列儲存」設定（更簡單且更穩定）。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Follow the steps below to create an automation for Chrome. If you use Safari, we recommend setting up \"Save From the Safari Toolbar\" above instead (it's simpler and more reliable)."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "아래 단계로 Chrome용 자동화를 만들 수 있습니다. Safari를 사용하신다면 위의 'Safari 툴바에서 저장' 설정을 추천합니다(더 간단하고 안정적으로 동작합니다)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sigue los pasos de abajo para crear una automatización para Chrome. Si usas Safari, te recomendamos configurar arriba \"Guardar desde la barra de herramientas de Safari\" (es más sencillo y fiable)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Mit den folgenden Schritten kannst du eine Automatisierung für Chrome erstellen. Falls du Safari verwendest, empfehlen wir stattdessen die oben stehende Einrichtung „Über die Safari-Symbolleiste sichern“ (einfacher und stabiler)."
          }
        }
      }
    },
