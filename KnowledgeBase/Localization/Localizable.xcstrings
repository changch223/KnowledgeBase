    "onboarding.page4.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "記事詳細の「訂正」ボタンから自然言語で指示するだけ（例: 「Claude Code を gloadcod と誤認識しています」）。分野の修正は次回の自動分類に活かされます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "只需在文章详情的「更正」按钮中用自然语言下达指示（例如：「Claude Code 被误认成了 gloadcod」）。类别的修正也会应用到下次的自动分类中。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "只需在文章詳情的「更正」按鈕中用自然語言下達指示（例如：「Claude Code 被誤認成了 gloadcod」）。類別的修正也會應用到下次的自動分類中。"
          }
        }
      }
    },
