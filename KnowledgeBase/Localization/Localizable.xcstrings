    "settings.safariSetup.confirmAutoSave.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Safari で開いたすべてのページがKnowledge Baseに自動保存されます。プライバシー保護のため、Cookie 同意画面 / 検索結果 / ログイン画面などは除外されます。後でいつでも OFF にできます。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Safari 中打开的所有网页都会自动保存到 Knowledge Base。为保护隐私，Cookie 同意画面、搜索结果、登录画面等会被排除在外。之后随时可以关闭。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Safari 中開啟的所有網頁都會自動儲存到 Knowledge Base。為保護隱私，Cookie 同意畫面、搜尋結果、登入畫面等會被排除在外。之後隨時可以關閉。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Every page you open in Safari will be automatically saved to Knowledge Base. To protect your privacy, cookie consent screens, search results, login pages, and similar pages are excluded. You can turn this off anytime."
          }
        }
      }
    },
