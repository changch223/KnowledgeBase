      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「アクション追加」→ 検索で「Knowledge Base」→「Knowledge Baseに保存」を選択。URL を「Chrome の現在の URL」に設定します。"
