    "onboarding.page1.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Knowledge Base はあなたが読んだ記事を AI が自動で整理し、必要なときに思い出せる「あなた専用の第二の脳」です。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base 会由 AI 自动整理你读过的文章，让你在需要时随时回想起来，是「专属于你的第二大脑」。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base 會由 AI 自動整理你讀過的文章，讓你在需要時隨時回想起來，是「專屬於你的第二大腦」。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base automatically organizes the articles you read with AI, making it your own \"second brain\" you can recall whenever you need."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base는 당신이 읽은 기사를 AI가 자동으로 정리하여, 필요할 때 떠올릴 수 있는 '당신만의 제2의 뇌'입니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base organiza automáticamente con IA los artículos que lees, convirtiéndose en tu propio \"segundo cerebro\" al que puedes recurrir cuando lo necesites."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base organisiert die von dir gelesenen Artikel automatisch mit KI und macht sie zu deinem eigenen „zweiten Gehirn“, das du dir jederzeit ins Gedächtnis rufen kannst."
          }
        }
      }
    },
    "onboarding.page1.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ようこそ Knowledge Base へ"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "欢迎使用 Knowledge Base"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "歡迎使用 Knowledge Base"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Welcome to Knowledge Base"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Knowledge Base에 오신 것을 환영합니다"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Bienvenido a Knowledge Base"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Willkommen bei Knowledge Base"
          }
        }
      }
    },
    "onboarding.page2.body" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "共有シートから記事をそのまま保存。＋ボタンなら URL・テキスト・ファイル・写真・音声も取り込めます。英語や中国語のコンテンツは自動で日本語に翻訳して整理します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "从共享面板可直接保存文章。使用「+」按钮还能导入 URL、文字、文件、照片、语音。英文或中文内容会自动翻译为日文后再整理。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "從共享面板可直接儲存文章。使用「+」按鈕還能匯入 URL、文字、檔案、照片、語音。英文或中文內容會自動翻譯為日文後再整理。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Save articles directly from the Share Sheet. The + button also lets you add URLs, text, files, photos, and audio. English or Chinese content is automatically translated to Japanese and organized."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "공유 시트에서 기사를 그대로 저장하세요. + 버튼으로 URL·텍스트·파일·사진·음성도 가져올 수 있습니다. 영어나 중국어 콘텐츠는 자동으로 한국어(일본어)로 번역해서 정리합니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Guarda artículos directamente desde la hoja de compartir. El botón + también te permite añadir URLs, texto, archivos, fotos y audio. El contenido en inglés o chino se traduce automáticamente al japonés y se organiza."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sichere Artikel direkt über das Teilen-Menü. Über die Plus-Schaltfläche kannst du auch URLs, Text, Dateien, Fotos und Audio hinzufügen. Englische oder chinesische Inhalte werden automatisch ins Deutsche übersetzt und organisiert."
          }
        }
      }
    },
    "onboarding.page2.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "どこからでも取り込める"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "随处都能导入"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
