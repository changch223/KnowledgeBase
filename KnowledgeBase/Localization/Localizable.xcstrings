    "settings.safariSetup.autoSaveExplain" : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Safari で開いた全ページを自動でKnowledge Baseに保存します。下の遅延設定で「ページを開いてから何秒後に保存するか」を選択。すでに保存済みのページは重複保存されません。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "自动将 Safari 中打开的所有网页保存到 Knowledge Base。可在下方的延迟设置中选择「打开网页后几秒保存」。已保存过的网页不会重复保存。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "自動將 Safari 中開啟的所有網頁儲存到 Knowledge Base。可在下方的延遲設定中選擇「開啟網頁後幾秒儲存」。已儲存過的網頁不會重複儲存。"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Automatically saves every page you open in Safari to Knowledge Base. Use the delay setting below to choose how many seconds after opening a page it should be saved. Already-saved pages won't be saved again."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Safari에서 연 모든 페이지를 자동으로 Knowledge Base에 저장합니다. 아래 지연 설정에서 '페이지를 연 후 몇 초 뒤에 저장할지'를 선택하세요. 이미 저장된 페이지는 중복 저장되지 않습니다."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Guarda automáticamente en Knowledge Base cada página que abres en Safari. Usa el ajuste de retraso de abajo para elegir cuántos segundos después de abrir una página se debe guardar. Las páginas ya guardadas no se volverán a guardar."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sichert automatisch jede Seite, die du in Safari öffnest, in Knowledge Base. Lege unten in der Verzögerungseinstellung fest, nach wie vielen Sekunden nach dem Öffnen einer Seite gesichert werden soll. Bereits gesicherte Seiten werden nicht erneut gesichert."
          }
        }
      }
    },
