        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Instructions can be left empty. AI will review the article for errors using your glossary (concept pages and tags) as reference. You'll be notified when it's done (you can close this screen)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Las instrucciones pueden dejarse vacías. La IA revisará el artículo en busca de errores usando tu glosario (páginas de concepto y etiquetas) como referencia. Se te avisará cuando termine (puedes cerrar esta pantalla)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "指示は空でもOK。AI が用語集（あなたの概念ページ・タグ）を手がかりに本文の誤りを見直します。完了したらお知らせします（この画面は閉じてOK）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "지시 사항은 비워 둬도 됩니다. AI가 용어집(당신의 개념 페이지·태그)을 참고해 본문의 오류를 검토합니다. 완료되면 알려드립니다(이 화면은 닫아도 됩니다)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "指示可以留空。AI 会参考术语表（你的概念页面、标签）来检查正文中的错误。完成后会通知你（此画面可以直接关闭）。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "指示可以留空。AI 會參考術語表（你的概念頁面、標籤）來檢查正文中的錯誤。完成後會通知你（此畫面可以直接關閉）。"
          }
        }
      }
    },
