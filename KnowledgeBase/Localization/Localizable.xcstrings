    "settings.languageSettings.confirmMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Dies ändert die Sprache, in der die KI Wissen generiert. Vorhandenes Wissen bleibt in der bisherigen Sprache erhalten. Ein Neustart der App ist erforderlich, damit die Änderung wirksam wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "This will change the language AI uses to generate knowledge. Existing knowledge remains in its previous language. Restarting the app is required for this to take effect."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Esto cambiará el idioma que usa la IA para generar conocimiento. El conocimiento existente permanecerá en su idioma anterior. Es necesario reiniciar la app para que el cambio surta efecto."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI が生成する知識の言語を変更します。既存の知識は前の言語のまま残ります。反映にはアプリの再起動が必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI가 생성하는 지식의 언어를 변경합니다. 기존 지식은 이전 언어로 그대로 남습니다. 반영하려면 앱을 다시 시작해야 합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "将更改 AI 生成知识所使用的语言。已有的知识仍会保留原本的语言。需要重新启动 App 才能生效。"
