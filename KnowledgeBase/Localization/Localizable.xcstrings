    "settings.safariSetup.step3.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Aktiviere unten den Schalter, um Seiten, die du in Safari öffnest, automatisch zu sichern. Bei deaktiviertem Schalter tippe zum Sichern auf das Knowledge Base-Symbol in der Symbolleiste."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Turn on the toggle below to auto-save pages you open in Safari. When it's off, tap the Knowledge Base icon in the toolbar to save manually."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Activa el interruptor de abajo para guardar automáticamente las páginas que abres en Safari. Si está desactivado, toca el icono de Knowledge Base en la barra de herramientas para guardar manualmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "下のトグルで自動保存を ON にすると、Safari で開いたページが自動で保存されます。OFF の場合はツールバーのKnowledge Baseアイコンタップで保存します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "아래 토글로 자동 저장을 ON으로 하면 Safari에서 연 페이지가 자동으로 저장됩니다. OFF인 경우 툴바의 Knowledge Base 아이콘을 탭해서 저장합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "打开下方开关启用自动保存后，Safari 中打开的网页会自动保存。关闭时，可点按工具栏中的 Knowledge Base 图标进行保存。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "開啟下方開關啟用自動儲存後，Safari 中開啟的網頁會自動儲存。關閉時，可點按工具列中的 Knowledge Base 圖示進行儲存。"
          }
        }
      }
    },
