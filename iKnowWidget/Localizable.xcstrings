    "widget.description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Zeigt eine Ambient-Ansicht der Karte, die die KI dir jetzt zum Erkunden empfiehlt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Shows an ambient display of the card AI thinks you should explore now."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Muestra en pantalla ambiental la tarjeta que la IA cree que deberías explorar ahora."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI が選んだ「今深めるべき」カードを ambient 表示します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "AI가 고른 '지금 더 알아볼' 카드를 앰비언트 화면으로 표시합니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "以环境显示方式呈现 AI 挑选出「现在该深入了解」的卡片。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "以環境顯示方式呈現 AI 挑選出「現在該深入了解」的卡片。"
          }
        }
      }
    },
    "widget.empty.mediumHint" : {
